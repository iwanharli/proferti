# Database (PostgreSQL — required for Prisma & Auth adapter)
# Contoh lokal (ganti YOUR_PASSWORD):
# DATABASE_URL="postgresql://iwanharli:YOUR_PASSWORD@localhost:5432/postgres?schema=public"
# Lebih aman: buat database khusus, lalu ganti nama DB di URL (mis. proferti).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth Configuration
AUTH_ORIGIN=http://localhost:3001
AUTH_SECRET=generate-a-long-random-string-here

# GitHub OAuth (Optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# SEO
NUXT_PUBLIC_SITE_URL=http://localhost:3001
