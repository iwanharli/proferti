# ==============================================================================
# PROFERTI ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================================

# --- BACKEND SERVICE URL ---
# URL of proferti-be (Go) — the single service that talks to the database.
BE_URL="http://localhost:8080"

# --- AUTHENTICATION CONFIGURATION (Sidebase/Auth.js) ---
# The base URL of your application.
AUTH_ORIGIN="http://localhost:3001"
NUXT_AUTH_ORIGIN="http://localhost:3001"

# Required by Next-Auth for callback resolution.
NEXTAUTH_URL="http://localhost:3001"

# A long random string used to encrypt cookies (min 32 chars recommended).
# Generate one: openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-string-here"

# --- OAUTH PROVIDERS (Optional) ---
# GitHub OAuth Credentials (register at github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- SITE CONFIGURATION ---
# Base URL for SEO and public-facing links.
NUXT_PUBLIC_SITE_URL="http://localhost:3001"
