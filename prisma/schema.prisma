generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth / User ────────────────────────────────────────────────────────────────
// Tabel dikelola oleh Go migrations (froferti-be).
// Prisma hanya digunakan untuk generate types — JANGAN jalankan prisma migrate.

model User {
  id            String     @id @default(uuid()) @db.Uuid
  name          String?
  email         String?    @unique
  password      String?    // nullable — OAuth users tidak punya password
  emailVerified DateTime?  @map("email_verified")
  image         String?
  role          String     @default("developer")

  // FK ke t_developers disimpan di sisi t_users (sesuai Go migration)
  developerId   String?    @unique @map("developer_id") @db.Uuid
  developer     Developer? @relation(fields: [developerId], references: [id])

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt      @map("updated_at")

  @@map("t_users")
}

// ── Developer ──────────────────────────────────────────────────────────────────

model Developer {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @map("company_name")
  slug        String    @unique
  ownerName   String?   @map("owner_name")
  phone       String?
  email       String?
  logo        String?
  coverImage  String?   @map("cover_image")
  address     String?
  description String?
  website     String?
  regionId    Int?      @map("region_id")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  user        User?
  projects    Project[]

  @@map("t_developers")
}

// ── Project ────────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @map("project_name")
  slug        String
  description String?
  startPrice  Float         @map("starting_price")
  promo       String?       @map("promo_text")
  image       String?       @map("cover_image")
  status      ProjectStatus @default(ACTIVE)
  featured    Boolean       @default(false)
  projectType String?       @map("project_type")
  locationId  String?       @map("location_id") @db.Uuid
  developerId String        @map("developer_id") @db.Uuid
  developer   Developer     @relation(fields: [developerId], references: [id])
  gallery     Gallery[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  @@unique([developerId, slug])
  @@map("t_projects")
}

// ── Gallery ────────────────────────────────────────────────────────────────────

model Gallery {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  image     String   @db.Text
  title     String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("t_project_galleries")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE    @map("active")
  SOLDOUT   @map("soldout")
  UPCOMING  @map("upcoming")
}
