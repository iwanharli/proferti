generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth.js Models
model Account {
  id                 String  @id @default(uuid()) @db.Uuid
  userId             String  @map("user_id") @db.Uuid
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("na_accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("na_sessions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime? @map("email_verified")
  image         String?
  developer     Developer?
  accounts      Account[]
  sessions      Session[]
  
  // Custom Proferti Fields
  role          String    @default("developer")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("t_users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("na_verification_tokens")
}


// Proferti Business Models
model Developer {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @map("company_name")
  slug        String    @unique
  ownerName   String?   @map("owner_name")
  phone       String?
  email       String?
  logo        String?
  description String?
  website     String?
  userId      String    @unique @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id])
  projects    Project[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("t_developers")
}

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @map("project_name")
  location    String
  slug        String
  description String?
  startPrice  Float     @map("starting_price")
  promo       String?   @map("promo_text")
  image       String?       @map("cover_image")
  status      ProjectStatus @default(AVAILABLE)
  developerId String        @map("developer_id") @db.Uuid
  developer   Developer @relation(fields: [developerId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  gallery     Gallery[]

  @@map("t_projects")
}


model Gallery {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  image     String   @db.Text
  title     String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("t_galleries")
}


enum ProjectStatus {
  AVAILABLE
  SOLD_OUT
  COMING_SOON
}
